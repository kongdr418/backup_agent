# MiniMax Agent 环境变量配置
# 复制此文件为 .env 并填入你的 API Keys

# MiniMax API (app.py 和 minimax_agent.py 使用)
MINIMAX_API_KEY=your_minimax_api_key_here

# DeepSeek API (课程大纲/讲稿/习题集/测验/知识卡片/思维导图 生成器使用)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# MiMo API (语音合成)
MIMO_API_KEY=your_mimo_api_key_here

# MiniMax Image API (封面图生成)
MINIMAX_IMAGE_API_KEY=your_minimax_image_api_key_here
